<style>
  /* ===== BANNER — IgniteU Theme ===== */
  .welcome-card {
    position: relative;
    background: linear-gradient(160deg, rgba(94,234,212,.09), rgba(2,16,30,.7));
    border: 1px solid var(--line);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-radius: 16px;
    padding: 1.1rem 1.4rem;
    margin: 10px 10px 12px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    overflow: hidden;
    min-height: 90px;
  }
  .welcome-card::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--mint), transparent);
    opacity: .45;
  }
  .welcome-content { flex: 1; }
  .welcome-content h2 { font: 700 1.25rem 'Inter', sans-serif; color: var(--text); margin-bottom: .2rem; letter-spacing: -.01em; }
  .welcome-content h2 .greeting { color: var(--mint); }
  .welcome-content h2 .username { color: #fff; }
  .welcome-content p { font-size: .82rem; color: var(--muted); margin: 0; font-family: 'JetBrains Mono', monospace; }
  .banner-right { display: flex; align-items: center; gap: 1.1rem; flex-shrink: 0; }
  .darkmode-icon {
    width: 34px; height: 34px;
    background: rgba(94,234,212,.1); border: 1px solid var(--line);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .25s, transform .25s, box-shadow .25s; flex-shrink: 0;
  }
  .darkmode-icon:hover { background: rgba(94,234,212,.2); border-color: var(--line-strong); box-shadow: 0 0 14px rgba(94,234,212,.25); transform: scale(1.08); }
  .darkmode-icon i { font-size: .95rem; color: var(--mint); }
  .datetime-section { text-align: right; }
  .date { font: 500 .72rem 'JetBrains Mono', monospace; color: var(--muted); letter-spacing: .5px; }
  .time { font: 700 1.1rem 'Inter', sans-serif; color: var(--text); letter-spacing: -.01em; }

  /* ===== EDU STRIP — two cards ===== */
  .edu-strip {
    margin: 0 10px 18px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .7rem;
  }

  /* shared card shell */
  .edu-card {
    position: relative;
    background: rgba(94,234,212,.04);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: .85rem 1rem .8rem;
    overflow: hidden;
    transition: background .2s, border-color .2s;
    display: flex;
    flex-direction: column;
  }
  .edu-card:hover { background: rgba(94,234,212,.07); border-color: var(--line-strong); }
  .edu-card::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--mint), transparent);
    opacity: .3;
  }

  /* header row: label + arrows */
  .edu-card-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: .45rem;
  }
  .edu-card-label {
    font: 600 .62rem 'JetBrains Mono', monospace;
    color: var(--mint); letter-spacing: 1.5px; text-transform: uppercase;
    display: flex; align-items: center; gap: .35rem;
  }
  .edu-arrows { display: flex; gap: .3rem; }
  .edu-arrow {
    width: 24px; height: 24px; border-radius: 50%;
    border: 1px solid var(--line); background: rgba(94,234,212,.07);
    color: var(--mint); display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: .6rem;
    transition: background .2s, border-color .2s, transform .15s;
  }
  .edu-arrow:hover { background: rgba(94,234,212,.16); border-color: var(--line-strong); transform: scale(1.1); }
  .edu-arrow:active { transform: scale(.92); }

  /* text */
  .edu-card-text {
    font: 400 .8rem 'Inter', sans-serif;
    color: var(--text); line-height: 1.55; flex: 1;
    transition: opacity .25s, transform .25s;
  }
  .edu-card-source {
    font: 400 .63rem 'JetBrains Mono', monospace;
    color: var(--muted-2); margin-top: .25rem; min-height: .85rem;
    transition: opacity .25s;
  }

  /* fade */
  .edu-fading { opacity: 0; transform: translateY(4px); }

  /* footer: dots + progress */
  .edu-card-footer {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: .55rem;
  }
  .edu-dots { display: flex; gap: .32rem; flex-wrap: wrap; }
  .edu-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--line-strong); cursor: pointer;
    transition: background .2s, transform .15s;
  }
  .edu-dot.active { background: var(--mint); transform: scale(1.3); }

  .edu-progress { height: 2px; width: 60px; border-radius: 999px; background: var(--line); overflow: hidden; display: none; }
  .edu-progress-fill { height: 100%; width: 0%; background: var(--mint); border-radius: 999px; }

  @media (max-width: 576px) {
    .welcome-card { padding: 1rem 1.1rem; min-height: 80px; gap: .7rem; }
    .welcome-content h2 { font-size: 1.05rem; }
    .welcome-content p { font-size: .75rem; }
    .time { font-size: .95rem; }
    .date { font-size: .68rem; }
    .edu-strip { grid-template-columns: 1fr; }
  }
  @media (max-width: 380px) {
    .welcome-card { padding: .85rem .9rem; }
    .welcome-content h2 { font-size: .95rem; }
    .darkmode-icon { width: 30px; height: 30px; }
    .darkmode-icon i { font-size: .85rem; }
  }
</style>

<!-- Banner -->
<div class="welcome-card">
  <div class="welcome-content">
    <h2>
      <span class="greeting" id="good">Welcome!</span>
      <% if (user) { %>
        <span class="username"> <%= user.username %></span>
      <% } %>
    </h2>
    <p>Ready for your next session?</p>
  </div>
  <div class="banner-right">
    <div class="darkmode-icon" id="darkModeToggle" title="Toggle dark mode">
      <i class="fa-regular fa-moon" id="darkModeIcon"></i>
    </div>
    <div class="datetime-section">
      <div class="date" id="date"></div>
      <div class="time" id="time"></div>
    </div>
  </div>
</div>

<!-- Education Strip -->
<div class="edu-strip">

  <!-- Study Tips carousel -->
  <div class="edu-card">
    <div class="edu-card-header">
      <div class="edu-card-label"><i class="fa-solid fa-lightbulb"></i> Study Tip</div>
      <div class="edu-arrows">
        <button class="edu-arrow" id="tipPrev"><i class="fa-solid fa-chevron-left"></i></button>
        <button class="edu-arrow" id="tipNext"><i class="fa-solid fa-chevron-right"></i></button>
      </div>
    </div>
    <div class="edu-card-text"   id="tipText"></div>
    <div class="edu-card-source" id="tipSource"></div>
    <div class="edu-card-footer">
      <div class="edu-dots"    id="tipDots"></div>
      <div class="edu-progress"><div class="edu-progress-fill" id="tipFill"></div></div>
    </div>
  </div>

  <!-- Did You Know carousel -->
  <div class="edu-card">
    <div class="edu-card-header">
      <div class="edu-card-label"><i class="fa-solid fa-flask"></i> Did You Know?</div>
      <div class="edu-arrows">
        <button class="edu-arrow" id="factPrev"><i class="fa-solid fa-chevron-left"></i></button>
        <button class="edu-arrow" id="factNext"><i class="fa-solid fa-chevron-right"></i></button>
      </div>
    </div>
    <div class="edu-card-text"   id="factText"></div>
    <div class="edu-card-source" id="factSource"></div>
    <div class="edu-card-footer">
      <div class="edu-dots"    id="factDots"></div>
      <div class="edu-progress"><div class="edu-progress-fill" id="factFill"></div></div>
    </div>
  </div>

</div>

<script>
(function () {
  /* ── greeting ── */
  var greetEl = document.getElementById('good');
  if (greetEl) {
    var h = new Date().getHours();
    greetEl.textContent = h < 12 ? 'Good Morning! ☀️' : h < 18 ? 'Good Afternoon! 🌤️' : 'Good Evening! 🌙';
  }

  /* ── live clock ── */
  function updateClock() {
    var now = new Date();
    var d = document.getElementById('date'), t = document.getElementById('time');
    if (d) d.textContent = now.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
    if (t) t.textContent = now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  /* ── dark mode ── */
  var toggle   = document.getElementById('darkModeToggle');
  var modeIcon = document.getElementById('darkModeIcon');
  function applyDarkMode(on) {
    document.body.classList.toggle('dark-mode', on);
    if (modeIcon) modeIcon.className = on ? 'fa-solid fa-sun' : 'fa-regular fa-moon';
  }
  applyDarkMode(localStorage.getItem('darkMode') === 'enabled');
  if (toggle) toggle.addEventListener('click', function () {
    var on = !document.body.classList.contains('dark-mode');
    localStorage.setItem('darkMode', on ? 'enabled' : 'disabled');
    applyDarkMode(on);
  });

  /* ── Generic carousel factory ── */
  function makeCarousel(opts) {
    var items    = opts.items;
    var INTERVAL = opts.interval || 5000;
    var textEl   = document.getElementById(opts.textId);
    var srcEl    = document.getElementById(opts.sourceId);
    var dotsEl   = document.getElementById(opts.dotsId);
    var fillEl   = document.getElementById(opts.fillId);
    var prevBtn  = document.getElementById(opts.prevId);
    var nextBtn  = document.getElementById(opts.nextId);

    var today = new Date();
    var idx   = (today.getDate() + today.getMonth() + (opts.offset || 0)) % items.length;
    var timer, progTimer, progStart;

    function buildDots() {
      if (!dotsEl) return;
      dotsEl.innerHTML = items.map(function (_, i) {
        return '<div class="edu-dot' + (i === idx ? ' active' : '') + '" data-i="' + i + '"></div>';
      }).join('');
      dotsEl.querySelectorAll('.edu-dot').forEach(function (dot) {
        dot.addEventListener('click', function () { goTo(parseInt(dot.dataset.i)); });
      });
    }

    function updateDots() {
      if (!dotsEl) return;
      dotsEl.querySelectorAll('.edu-dot').forEach(function (d, i) {
        d.classList.toggle('active', i === idx);
      });
    }

    function startProgress() {
      clearInterval(progTimer);
      if (!fillEl) return;
      fillEl.style.width = '0%';
      progStart = Date.now();
      progTimer = setInterval(function () {
        var pct = Math.min(100, ((Date.now() - progStart) / INTERVAL) * 100);
        fillEl.style.width = pct + '%';
        if (pct >= 100) clearInterval(progTimer);
      }, 50);
    }

    function show(animate) {
      var item = items[idx];
      if (!animate) {
        if (textEl) textEl.textContent = item.text;
        if (srcEl)  srcEl.textContent  = item.source ? '— ' + item.source : '';
        updateDots(); startProgress(); return;
      }
      if (textEl) textEl.classList.add('edu-fading');
      if (srcEl)  srcEl.classList.add('edu-fading');
      setTimeout(function () {
        var it = items[idx];
        if (textEl) { textEl.textContent = it.text; textEl.classList.remove('edu-fading'); }
        if (srcEl)  { srcEl.textContent  = it.source ? '— ' + it.source : ''; srcEl.classList.remove('edu-fading'); }
        updateDots(); startProgress();
      }, 260);
    }

    function goTo(i) {
      idx = (i + items.length) % items.length;
      clearInterval(timer);
      show(true);
      timer = setInterval(function () { idx = (idx + 1) % items.length; show(true); }, INTERVAL);
    }

    buildDots();
    show(false);
    timer = setInterval(function () { idx = (idx + 1) % items.length; show(true); }, INTERVAL);

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(idx - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(idx + 1); });
  }

  /* ── Study Tips ── */
  makeCarousel({
    textId: 'tipText', sourceId: 'tipSource', dotsId: 'tipDots',
    fillId: 'tipFill', prevId: 'tipPrev', nextId: 'tipNext',
    interval: 5000, offset: 0,
    items: [
      { text: "Use the Pomodoro method — study for 25 minutes, then rest for 5. Consistency beats long cramming sessions.", source: "" },
      { text: "Write by hand when memorising key points. Studies show handwriting improves long-term retention.", source: "" },
      { text: "Teach what you just learned to an imaginary student. If you can explain it simply, you truly understand it.", source: "" },
      { text: "Review your notes within 24 hours of a lecture. Forgetting is fastest in the first day — catch it early.", source: "" },
      { text: "Interleave subjects during study sessions instead of blocking one topic all day. It strengthens recall.", source: "" },
      { text: "Sleep is not optional — memory consolidation happens during deep sleep. Aim for 7–9 hours before exams.", source: "" },
      { text: "Use past exam questions as your primary revision tool. Pattern recognition is faster than re-reading notes.", source: "" },
      { text: "Break large topics into small chunks and tackle one chunk per session. Progress feels real and sustainable.", source: "" }
    ]
  });

  /* ── Did You Know ── */
  makeCarousel({
    textId: 'factText', sourceId: 'factSource', dotsId: 'factDots',
    fillId: 'factFill', prevId: 'factPrev', nextId: 'factNext',
    interval: 5000, offset: 3,
    items: [
      { text: "Spaced repetition can improve long-term memory by up to 200% compared to massed practice (cramming).", source: "Cognitive Psychology" },
      { text: "The human brain can store roughly 2.5 petabytes of information — equivalent to 3 million hours of TV.", source: "Neuroscience Research" },
      { text: "Students who take handwritten notes score higher on conceptual questions than those who type their notes.", source: "Mueller & Oppenheimer, 2014" },
      { text: "Exercise before studying increases BDNF — a protein that strengthens neural connections and aids learning.", source: "Harvard Medical School" },
      { text: "Reading aloud improves memory recall significantly — a phenomenon called the 'production effect'.", source: "University of Waterloo, 2017" },
      { text: "The Feynman Technique (explain simply → find gaps → revise) is one of the most effective learning strategies known.", source: "Richard Feynman, Nobel Laureate" },
      { text: "Albert Einstein did not speak fluently until age 9. Late development does not determine future capability.", source: "Historical Record" },
      { text: "Mathematics is the only language shared by all human cultures and is considered a universal language.", source: "Philosophy of Science" }
    ]
  });
})();
</script>