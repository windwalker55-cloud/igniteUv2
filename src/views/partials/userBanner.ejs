<style>
  /* ===== BANNER — IgniteU Theme ===== */
  .welcome-card {
    position: relative;
    background: linear-gradient(160deg, rgba(94,234,212,.09), rgba(6,32,50,.7));
    border: 1px solid var(--line);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-radius: 16px;
    padding: 1.1rem 1.4rem;
    margin: 10px 10px 12px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    overflow: hidden;
    min-height: 90px;
  }
  .welcome-card::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--mint), transparent);
    opacity: .45;
  }

  .welcome-content { flex: 1; }
  .welcome-content h2 {
    font: 700 1.1rem 'Inter', sans-serif;
    color: var(--text); margin-bottom: .2rem; letter-spacing: -.01em;
  }
  .welcome-content h2 .greeting { color: var(--mint); }
  .welcome-content h2 .username { color: #fff; }
  .welcome-content p {
    font-size: .78rem; color: var(--muted); margin: 0;
    font-family: 'JetBrains Mono', monospace;
  }

  .banner-right { display: flex; align-items: center; gap: 1.1rem; flex-shrink: 0; }
  .datetime-section { text-align: right; }
  .date { font: 500 .72rem 'JetBrains Mono', monospace; color: var(--muted); letter-spacing: .5px; }
  .time { font: 700 1rem 'Inter', sans-serif; color: var(--text); letter-spacing: -.01em; }

  @media (max-width: 768px) {
    .welcome-card       { padding: 1rem 1.2rem; min-height: 80px; }
    .welcome-content h2 { font-size: 1rem; }
    .welcome-content p  { font-size: .82rem; }
    .time               { font-size: .95rem; }
    .date               { font-size: .7rem; }
  }
  @media (max-width: 576px) {
    .welcome-card       { padding: .9rem 1rem; min-height: 75px; gap: .75rem; }
    .welcome-content h2 { font-size: .95rem; }
    .welcome-content p  { font-size: .78rem; }
    .time               { font-size: .88rem; }
  }
  @media (max-width: 380px) {
    .welcome-card       { padding: .85rem .9rem; }
    .welcome-content h2 { font-size: .88rem; }
    .date               { display: none; }
  }
</style>

<!-- Banner -->
<div class="welcome-card">
  <div class="welcome-content">
    <h2>
      <span class="greeting" id="good">Welcome!</span>
      <% if (user) { %>
        <span class="username"> <%= user.username %></span>
      <% } %>
    </h2>
    <p>Ready for your next session?</p>
  </div>
  <div class="banner-right">
    <div class="datetime-section">
      <div class="date" id="date"></div>
      <div class="time" id="time"></div>
    </div>
  </div>
</div>

<script>
(function () {
  var greetEl = document.getElementById('good');
  if (greetEl) {
    var h = new Date().getHours();
    greetEl.textContent = h < 12 ? 'Good Morning! ☀️' : h < 18 ? 'Good Afternoon! 🌤️' : 'Good Evening! 🌙';
  }

  function updateClock() {
    var now = new Date();
    var d = document.getElementById('date');
    var t = document.getElementById('time');
    if (d) d.textContent = now.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
    if (t) t.textContent = now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 1000);
})();
</script>