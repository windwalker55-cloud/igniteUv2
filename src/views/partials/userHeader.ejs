<style>
  /* ===== HEADER — IgniteU Theme ===== */
  * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', system-ui, sans-serif; -webkit-tap-highlight-color: transparent; }

  .dashboard-header {
    background: rgba(2,10,20,.85);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    padding: .8rem 2rem;
    display: flex; justify-content: space-between; align-items: center;
    position: sticky; top: 0; z-index: 200; gap: .5rem;
    border-bottom: 1px solid var(--line);
  }

  /* Logo */
  .logo-section { display: flex; align-items: center; gap: .75rem; flex: 1; }
  .logo {
    width: 40px; height: 40px; border-radius: 10px; overflow: hidden;
    border: 1px solid var(--line-strong);
    box-shadow: 0 0 18px rgba(94,234,212,.3); flex-shrink: 0;
  }
  .logo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .header-title h1 { font-size: 1.2rem; font-weight: 700; color: #fff; letter-spacing: -.01em; }
  .header-title p  { font-size: .7rem; color: rgba(255,255,255,.6); font-family: 'JetBrains Mono', monospace; }

  /* Right section */
  .right-section { display: flex; align-items: center; gap: 1.2rem; }

  /* ── Notification bell ── */
  .notif-wrapper { position: relative; }

  .notification-bell {
    width: 38px; height: 38px; border-radius: 50%; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    background: rgba(94,234,212,.07); border: 1px solid var(--line);
    transition: background .2s, border-color .2s, transform .15s;
    position: relative;
  }
  .notification-bell:hover { background: rgba(94,234,212,.14); border-color: var(--line-strong); }
  .notification-bell:active { transform: scale(.93); }
  .notification-bell i { font-size: 1rem; color: var(--muted); transition: color .2s; }
  .notification-bell:hover i { color: var(--mint); }

  /* Badge */
  .notif-badge {
    position: absolute; top: -3px; right: -3px;
    width: 17px; height: 17px; border-radius: 50%;
    background: linear-gradient(135deg, #ef4444, #f97316);
    color: #fff; font: 700 .6rem 'Inter', sans-serif;
    display: flex; align-items: center; justify-content: center;
    border: 2px solid rgba(2,10,20,.9);
    transition: transform .2s;
  }
  .notif-badge.hidden { display: none; }

  /* ── Dropdown panel ── */
  .notif-panel {
    display: none;
    position: absolute; top: calc(100% + .6rem); right: 0;
    width: 320px;
    background: #0c1e1b; border: 1px solid var(--line);
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,.6);
    z-index: 300;
    animation: notif-drop .18s ease;
  }
  .notif-panel.open { display: block; }

  @keyframes notif-drop {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  .notif-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: .8rem 1rem .7rem; border-bottom: 1px solid var(--line);
  }
  .notif-panel-title { font: 700 .88rem 'Inter', sans-serif; color: var(--text); }
  .notif-mark-all {
    font: 500 .65rem 'JetBrains Mono', monospace; color: var(--mint);
    background: none; border: none; cursor: pointer; letter-spacing: .3px;
    transition: opacity .15s;
  }
  .notif-mark-all:hover { opacity: .7; }

  /* Notification list */
  .notif-list { max-height: 320px; overflow-y: auto; }
  .notif-list::-webkit-scrollbar { width: 3px; }
  .notif-list::-webkit-scrollbar-track { background: transparent; }
  .notif-list::-webkit-scrollbar-thumb { background: var(--line-strong); border-radius: 10px; }

  .notif-item {
    display: flex; gap: .75rem; padding: .75rem 1rem;
    border-bottom: 1px solid var(--line);
    transition: background .15s; cursor: default;
    position: relative;
  }
  .notif-item:last-child { border-bottom: none; }
  .notif-item:hover { background: rgba(94,234,212,.05); }
  .notif-item.unread { background: rgba(94,234,212,.04); }
  .notif-item.unread::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--mint); border-radius: 0 2px 2px 0;
  }

  .notif-icon {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    background: rgba(94,234,212,.1); border: 1px solid var(--line);
    display: flex; align-items: center; justify-content: center; font-size: .88rem;
  }

  .notif-body { flex: 1; min-width: 0; }
  .notif-text {
    font: 400 .78rem 'Inter', sans-serif; color: var(--text);
    line-height: 1.45; margin-bottom: .2rem;
  }
  .notif-text strong { font-weight: 600; color: var(--mint); }
  .notif-time { font: 400 .62rem 'JetBrains Mono', monospace; color: var(--muted-2); }

  /* Panel footer */
  .notif-panel-footer {
    padding: .65rem 1rem; border-top: 1px solid var(--line); text-align: center;
  }
  .notif-view-all {
    font: 600 .72rem 'Inter', sans-serif; color: var(--mint);
    text-decoration: none; letter-spacing: .2px;
    transition: opacity .15s;
  }
  .notif-view-all:hover { opacity: .7; }

  /* Empty state */
  .notif-empty {
    display: none; padding: 2rem 1rem; text-align: center;
    color: var(--muted); font: 400 .8rem 'JetBrains Mono', monospace;
  }

  /* Avatar */
  .user-profile { display: flex; align-items: center; cursor: pointer; }
  .user-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: linear-gradient(135deg, var(--mint-bright, #6ee7b7), var(--mint-deep, #2dd4bf));
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 1rem; color: #022;
    transition: transform .2s, box-shadow .2s;
  }
  .user-avatar a {
    color: #022; text-decoration: none; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 100%;
  }
  .user-profile:hover .user-avatar { transform: scale(1.05); box-shadow: 0 0 20px rgba(94,234,212,.5); }

  /* Menu toggle */
  .menu-toggle { display: none; background: none; border: none; color: var(--text); font-size: 1.5rem; cursor: pointer; padding: .3rem; }
  .menu-toggle:hover { color: var(--mint); }
  .menu-toggle:active, .notification-bell:active, .user-profile:active { transform: scale(.95); }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    /* -- container -- */
    .dashboard-header   { padding: 1rem 1.4rem; }
    /* -- logo image -- */
    .logo               { width: 44px; height: 44px; }
    /* -- logo text -- */
    .header-title h1    { font-size: 1.35rem; }
    .header-title p     { font-size: .95rem; }
    /* -- right icons -- */
    .notification-bell  { width: 44px; height: 44px; }
    .notification-bell i{ font-size: 1.15rem; }
    .user-avatar        { width: 44px; height: 44px; font-size: 1.1rem; }
    /* -- hamburger -- */
    .menu-toggle        { display: block; font-size: 1.7rem; }
    /* -- gap -- */
    .right-section      { gap: 1.1rem; }
    /* -- notif panel -- */
    .notif-panel        { width: 300px; }
  }

  @media (max-width: 576px) {
    /* -- container -- */
    .dashboard-header   { padding: .9rem 1.1rem; }
    /* -- logo image -- */
    .logo               { width: 42px; height: 42px; }
    /* -- logo text -- */
    .header-title h1    { font-size: 1.2rem; }
    .header-title p     { font-size: .85rem; }
    /* -- right icons -- */
    .notification-bell  { width: 42px; height: 42px; }
    .notification-bell i{ font-size: 1.1rem; }
    .user-avatar        { width: 42px; height: 42px; font-size: 1rem; }
    /* -- hamburger -- */
    .menu-toggle        { font-size: 1.6rem; }
    /* -- gap -- */
    .right-section      { gap: 1rem; }
    /* -- notif panel -- */
    .notif-panel        { width: calc(100vw - 2rem); right: -1rem; }
  }

  @media (max-width: 380px) {
    /* -- container -- */
    .dashboard-header   { padding: .8rem .9rem; }
    /* -- logo image -- */
    .logo               { width: 38px; height: 38px; }
    /* -- logo text -- */
    .header-title h1    { font-size: 1.1rem; }
    .header-title p     { font-size: .8rem; }
    /* -- right icons -- */
    .notification-bell  { width: 38px; height: 38px; }
    .user-avatar        { width: 38px; height: 38px; font-size: .95rem; }
    /* -- hamburger -- */
    .menu-toggle        { font-size: 1.5rem; }
    /* -- gap -- */
    .right-section      { gap: .8rem; }
  }
</style>

<header class="dashboard-header">
  <button class="menu-toggle" onclick="toggleSidebar()">☰</button>

  <div id="header_logo" class="logo-section">
    <div class="logo">
      <img src="https://www.image2url.com/r2/default/images/1777061825417-959bf371-403b-4859-bbfd-ec4f516a2797.jpeg" alt="IgniteU Logo">
    </div>
    <div class="header-title">
      <h1>IgniteU</h1>
      <p>Spark Your Success</p>
    </div>
  </div>

  <div class="right-section">

    <!-- Notification bell -->
    <div class="notif-wrapper">
      <div class="notification-bell" id="notifBell" onclick="window.toggleNotifPanel()">
        <i class="fa-regular fa-bell"></i>
        <span class="notif-badge" id="notifBadge">3</span>
      </div>

      <!-- Dropdown -->
      <div class="notif-panel" id="notifPanel">
        <div class="notif-panel-header">
          <span class="notif-panel-title">Notifications</span>
          <button class="notif-mark-all" onclick="window.markAllRead()">Mark all as read</button>
        </div>

        <div class="notif-list" id="notifList">
          <div class="notif-item unread">
            <div class="notif-icon">📝</div>
            <div class="notif-body">
              <div class="notif-text">New quiz available: <strong>STA 223 — Statistics</strong>. Test your knowledge now.</div>
              <div class="notif-time">2 hours ago</div>
            </div>
          </div>
          <div class="notif-item unread">
            <div class="notif-icon">🏆</div>
            <div class="notif-body">
              <div class="notif-text">You ranked <strong>#3 on the Leaderboard</strong> this week. Keep it up!</div>
              <div class="notif-time">1 day ago</div>
            </div>
          </div>
          <div class="notif-item unread">
            <div class="notif-icon">📚</div>
            <div class="notif-body">
              <div class="notif-text">New study materials added for <strong>CSC 201</strong> and <strong>MATH 101</strong>.</div>
              <div class="notif-time">2 days ago</div>
            </div>
          </div>
          <div class="notif-item">
            <div class="notif-icon">📢</div>
            <div class="notif-body">
              <div class="notif-text"><strong>Admin:</strong> Final exams start Dec 15th. Review the full schedule.</div>
              <div class="notif-time">3 days ago</div>
            </div>
          </div>
          <div class="notif-item">
            <div class="notif-icon">⚡</div>
            <div class="notif-body">
              <div class="notif-text">Practice test for <strong>PHY 101</strong> is now available with 60 new questions.</div>
              <div class="notif-time">5 days ago</div>
            </div>
          </div>
        </div>

        <div class="notif-empty" id="notifEmpty">You're all caught up! 🎉</div>

        <div class="notif-panel-footer">
          <a class="notif-view-all" href="/notifications">View all notifications</a>
        </div>
      </div>
    </div>

    <!-- Avatar -->
    <div class="user-profile" onclick="toggleProfileMenu()">
      <div class="user-avatar">
        <a href="/profile">
          <% if (user && user.username) { %>
            <%= user.username.substring(0, 1).toUpperCase() %>
          <% } else { %>
            U
          <% } %>
        </a>
      </div>
    </div>

  </div>
</header>

<script>
(function () {
  if (window.__headerReady) return;
  window.__headerReady = true;

  var unreadCount = 3;

  function updateBadge() {
    var badge = document.getElementById('notifBadge');
    if (!badge) return;
    if (unreadCount > 0) {
      badge.textContent = unreadCount;
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }

  window.toggleNotifPanel = function () {
    var panel = document.getElementById('notifPanel');
    if (!panel) return;
    panel.classList.toggle('open');
  };

  window.markAllRead = function () {
    var items = document.querySelectorAll('.notif-item.unread');
    items.forEach(function (el) { el.classList.remove('unread'); });
    unreadCount = 0;
    updateBadge();
    var empty = document.getElementById('notifEmpty');
    var list  = document.getElementById('notifList');
    if (document.querySelectorAll('.notif-item').length === 0 && empty && list) {
      list.style.display  = 'none';
      empty.style.display = 'block';
    }
  };

  document.addEventListener('click', function (e) {
    var wrapper = document.querySelector('.notif-wrapper');
    var panel   = document.getElementById('notifPanel');
    if (panel && wrapper && !wrapper.contains(e.target)) {
      panel.classList.remove('open');
    }
  });

  updateBadge();
})();
</script>