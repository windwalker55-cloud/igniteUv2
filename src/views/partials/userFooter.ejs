<style>
  /* ===== FOOTER — IgniteU Theme ===== */
  .dashboard-footer {
    background: rgba(2, 10, 20, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-top: 1px solid var(--line);
    color: var(--text);
    padding: 3rem 1.5rem 1rem;
    margin-top: auto;
  }

  .footer-container { max-width: 1200px; margin: 0 auto; }

  .footer-main {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }

  /* brand */
  .footer-brand { display: flex; flex-direction: column; gap: 1.2rem; }
  .footer-logo  { display: flex; align-items: center; gap: 0.9rem; }

  .footer-logo-img {
    width: 44px; height: 44px;
    border-radius: 10px; overflow: hidden;
    border: 1px solid var(--line-strong);
    box-shadow: 0 0 16px rgba(94,234,212,.25);
    flex-shrink: 0;
  }
  .footer-logo-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .footer-brand-info h3 { font: 700 1.1rem 'Inter', sans-serif; color: #fff; margin: 0; }
  .footer-brand-info p  { font: 400 0.72rem 'JetBrains Mono', monospace; color: var(--muted); margin: 0.2rem 0 0; }

  .footer-description { font-size: 0.88rem; line-height: 1.65; color: var(--muted); }

  .footer-social { display: flex; gap: 0.65rem; flex-wrap: wrap; }

  .social-link {
    width: 38px; height: 38px;
    background: rgba(94,234,212,.07);
    border: 1px solid var(--line);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
    transition: background .25s, color .25s, transform .25s, box-shadow .25s;
  }
  .social-link:hover {
    background: rgba(94,234,212,.15);
    border-color: var(--line-strong);
    color: var(--mint);
    transform: translateY(-3px);
    box-shadow: 0 6px 18px rgba(94,234,212,.2);
  }

  /* links grid */
  .footer-links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

  .link-group h4 {
    font: 700 0.72rem 'JetBrains Mono', monospace;
    color: var(--mint);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
  }
  .link-group ul  { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .link-group a   { color: var(--muted); text-decoration: none; font-size: 0.88rem; transition: color .2s, transform .2s; display: inline-block; }
  .link-group a:hover { color: var(--mint); transform: translateX(4px); }

  /* newsletter */
  .footer-newsletter { display: flex; flex-direction: column; gap: 1rem; }
  .footer-newsletter h4 {
    font: 700 0.72rem 'JetBrains Mono', monospace;
    color: var(--mint);
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .footer-newsletter p { font-size: 0.88rem; color: var(--muted); line-height: 1.55; }

  .newsletter-form { display: flex; flex-direction: column; gap: 0.65rem; }
  .newsletter-form input {
    padding: .82rem 1rem;
    background: rgba(94,234,212,.05);
    border: 1px solid var(--line);
    border-radius: 12px;
    color: var(--text);
    font: 400 .9rem 'Inter', sans-serif;
    outline: none;
    transition: border-color .25s, box-shadow .25s, background .25s;
  }
  .newsletter-form input::placeholder { color: var(--muted-2); }
  .newsletter-form input:focus {
    border-color: var(--mint);
    background: rgba(94,234,212,.08);
    box-shadow: 0 0 0 3px rgba(94,234,212,.12);
  }

  .subscribe-btn {
    padding: .82rem 1.4rem;
    border-radius: 999px; border: none; cursor: pointer;
    background: linear-gradient(135deg, var(--mint-bright), var(--mint-deep));
    color: #022;
    font: 700 .9rem 'Inter', sans-serif;
    box-shadow: 0 6px 24px rgba(94,234,212,.4);
    transition: transform .25s, box-shadow .25s;
    letter-spacing: -.01em;
    display: flex; align-items: center; justify-content: center; gap: .5rem;
  }
  .subscribe-btn:hover  { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(94,234,212,.55); }
  .subscribe-btn:active { transform: translateY(0); }

  /* bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--line);
    padding-top: 1.4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: .75rem;
    font: 500 .78rem 'JetBrains Mono', monospace;
    color: var(--muted-2);
  }
  .footer-bottom-links { display: flex; gap: 1.4rem; flex-wrap: wrap; }
  .footer-bottom-links a { color: var(--muted-2); text-decoration: none; transition: color .2s; }
  .footer-bottom-links a:hover { color: var(--mint); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .footer-main { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-links { grid-column: 1 / -1; }
    .footer-newsletter { grid-column: 1 / -1; max-width: 480px; }
  }
    @media (max-width: 768px) {
    .dashboard-footer     { padding: 2.2rem 1.2rem .9rem; }
    .footer-main          { grid-template-columns: 1fr; gap: 1.8rem; }
    .footer-links         { grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
    .footer-bottom        { flex-direction: column; text-align: center; }
    .footer-bottom-links  { justify-content: center; }
    .footer-brand-info h3 { font-size: 1rem; }
    .footer-brand-info p  { font-size: .72rem; }
    .footer-description   { font-size: .88rem; }
    .link-group h4        { font-size: .7rem; }
    .link-group a         { font-size: .88rem; }
    .footer-newsletter p  { font-size: .88rem; }
    .newsletter-form input { font-size: .88rem; padding: .85rem 1rem; }
    .subscribe-btn        { font-size: .88rem; padding: .85rem 1.4rem; }
    .footer-bottom        { font-size: .78rem; }
    .footer-bottom-links a { font-size: .78rem; }
    .social-link          { width: 38px; height: 38px; font-size: .95rem; }
  }
  @media (max-width: 480px) {
    .footer-links  { gap: 1rem; }
    .link-group h4 { font-size: .65rem; }
    .link-group a  { font-size: .85rem; }
    .social-link   { width: 36px; height: 36px; font-size: .9rem; }
  }
</style>

<footer class="dashboard-footer">
  <div class="footer-container">
    <div class="footer-main">

      <!-- Brand -->
      <div class="footer-brand">
        <div class="footer-logo">
          <div class="footer-logo-img">
            <img src="https://www.image2url.com/r2/default/images/1777061825417-959bf371-403b-4859-bbfd-ec4f516a2797.jpeg" alt="IgniteU">
          </div>
          <div class="footer-brand-info">
            <h3>IgniteU</h3>
            <p>Spark Your Success</p>
          </div>
        </div>
        <p class="footer-description">Empowering students with advanced testing and learning tools for academic excellence.</p>
        <div class="footer-social">
          <a href="#" class="social-link" title="Facebook"><i class="fa-brands fa-facebook"></i></a>
          <a href="#" class="social-link" title="Instagram"><i class="fa-brands fa-instagram"></i></a>
          <a href="#" class="social-link" title="YouTube"><i class="fa-brands fa-youtube"></i></a>
          <a href="#" class="social-link" title="Twitter/X"><i class="fa-brands fa-x-twitter"></i></a>
          <a href="#" class="social-link" title="Discord"><i class="fa-brands fa-discord"></i></a>
        </div>
      </div>

      <!-- Links -->
      <div class="footer-links">
        <div class="link-group">
          <h4>Dashboard</h4>
          <ul>
            <li><a href="/homepage">Home</a></li>
            <li><a href="/history">History</a></li>
            <li><a href="/ai">AI Assistant</a></li>
            <li><a href="/leaderboard">Leaderboard</a></li>
          </ul>
        </div>
        <div class="link-group">
          <h4>Practice</h4>
          <ul>
            <li><a href="/quickquiz">Quick Quiz</a></li>
            <li><a href="/mocktest">Mock Test</a></li>
            <li><a href="/materials">Study Materials</a></li>
            <li><a href="/mockexam">Mock Exam</a></li>
          </ul>
        </div>
        <div class="link-group">
          <h4>Support</h4>
          <ul>
            <li><a href="/help">Help Center</a></li>
            <li><a href="/contact">Contact Us</a></li>
            <li><a href="/report">Report Issue</a></li>
            <li><a href="/faq">FAQ</a></li>
          </ul>
        </div>
      </div>

      <!-- Newsletter -->
      <div class="footer-newsletter">
        <h4>Stay Updated</h4>
        <p>Subscribe to get notified about new features and updates.</p>
        <form class="newsletter-form" onsubmit="igSubscribe(event)">
          <input type="email" placeholder="your@email.com" required>
          <button type="submit" class="subscribe-btn">
            Subscribe <i class="fa-solid fa-paper-plane"></i>
          </button>
        </form>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span>© 2026 IgniteU — All rights reserved.</span>
      <div class="footer-bottom-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/cookies">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>

<script>
(function () {
  if (window.__footerReady) return;
  window.__footerReady = true;

  window.igSubscribe = function (e) {
    e.preventDefault();
    var input = e.target.querySelector('input[type="email"]');
    alert('Thank you for subscribing with ' + input.value + '!');
    e.target.reset();
  };
})();
</script>