<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — IgniteU</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
 <style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  /* ── DARK (default) ── */
  :root {
    --mint:        #5eead4;
    --mint-bright: #6ee7b7;
    --mint-deep:   #2dd4bf;
    --bg-0:        #020f1c;
    --bg-1:        #03101e;
    --bg-2:        #062032;
    --bg-card:     linear-gradient(160deg, rgba(94,234,212,.07), rgba(2,16,30,.65));
    --line:        rgba(94,234,212,.18);
    --line-strong: rgba(94,234,212,.4);
    --text:        #e6fff8;
    --muted:       rgba(230,255,248,.55);
    --muted-2:     rgba(230,255,248,.35);
    --shadow-card: 0 30px 80px -20px rgba(94,234,212,.2);
    --glow-a:      rgba(94,234,212,.14);
    --glow-b:      rgba(45,212,191,.08);
    --glow-c:      rgba(94,234,212,.06);
    --stars-opacity: .35;
    --vignette:    radial-gradient(ellipse at top, transparent 30%, rgba(2,10,20,.9) 90%);
  }

  /* ── LIGHT ── */
  [data-theme="light"] {
    --bg-0:        #f0faf8;
    --bg-1:        #e8f7f4;
    --bg-2:        #d4f0ea;
    --bg-card:     linear-gradient(160deg, rgba(94,234,212,.12), rgba(240,250,248,.85));
    --line:        rgba(45,212,191,.25);
    --line-strong: rgba(45,212,191,.55);
    --text:        #0a2a24;
    --muted:       rgba(10,42,36,.55);
    --muted-2:     rgba(10,42,36,.38);
    --shadow-card: 0 20px 60px -10px rgba(45,212,191,.18);
    --glow-a:      rgba(94,234,212,.22);
    --glow-b:      rgba(45,212,191,.12);
    --glow-c:      rgba(94,234,212,.10);
    --stars-opacity: 0;
    --vignette:    radial-gradient(ellipse at top, transparent 30%, rgba(220,245,240,.7) 90%);
  }

  a { text-decoration: none; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text);
    background: var(--bg-0);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    position: relative;
    transition: background .3s, color .3s;
  }

  /* ── Ambient background ── */
  .bg-scene {
    position: fixed; inset: 0; z-index: 0;
    overflow: hidden; pointer-events: none;
  }
  .bg-scene .glow {
    position: absolute; inset: -20%;
    background:
      radial-gradient(60% 40% at 50% 0%,  var(--glow-a), transparent 60%),
      radial-gradient(50% 40% at 80% 50%, var(--glow-b), transparent 65%),
      radial-gradient(50% 40% at 10% 80%, var(--glow-c), transparent 65%);
    filter: blur(20px);
    transition: background .4s;
  }
  .bg-scene .stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%,  rgba(255,255,255,.6),  transparent),
      radial-gradient(1px 1px at 70% 80%,  rgba(94,234,212,.5),   transparent),
      radial-gradient(1px 1px at 40% 60%,  rgba(255,255,255,.5),  transparent),
      radial-gradient(1px 1px at 90% 20%,  rgba(110,231,183,.5),  transparent),
      radial-gradient(1px 1px at 10% 90%,  rgba(255,255,255,.4),  transparent),
      radial-gradient(2px 2px at 55% 15%,  rgba(255,255,255,.4),  transparent);
    background-size: 700px 700px;
    opacity: var(--stars-opacity);
    transition: opacity .4s;
  }
  .bg-scene .vignette {
    position: absolute; inset: 0;
    background: var(--vignette);
    transition: background .4s;
  }

  /* ── Layout ── */
  .container {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    min-height: 100vh; width: 100%;
  }
  .main-wrapper { display: flex; flex: 1; }
  .content {
    flex: 0.99; margin-right: 10px;
    display: flex; flex-direction: column;
  }
  .content-wrapper { display: flex; flex-direction: column; width: 100%; }
</style>

  <!-- Ambient glow background -->
  <div class="bg-scene">
    <div class="glow"></div>
    <div class="stars"></div>
    <div class="vignette"></div>
  </div>

  <div class="container">
    <%- include('../partials/userHeader') %>

    <main class="main-wrapper">
      <%- include('../partials/userAside') %>
      <div class="content">
        <div class="content-wrapper">
          <%- include('../partials/userBanner') %>
          <%- body %>
        </div>
      </div>
    </main>

    <%- include('../partials/userFooter') %>
  </div>



  

</body>
</html>