<script>
(function () {
  if (window.__ignExam) return;
  window.__ignExam = true;

  var TOTAL   = 60;
  var current = 0;
  var answers = new Array(TOTAL).fill(null);
  var flagged = new Array(TOTAL).fill(false);

  /* ── Sample questions (replace with EJS loop output) ── */
  var questions = [
    { text: "What is the value of x in the equation 3x + 7 = 22?",            opts: ["x = 3","x = 5","x = 7","x = 9"] },
    { text: "Which measure of central tendency is most affected by outliers?", opts: ["Mode","Median","Mean","Range"] },
    { text: "A fair coin is tossed. What is the probability of getting heads?", opts: ["1/4","1/3","1/2","2/3"] },
    { text: "The data set is: 2, 4, 4, 6, 8. What is the variance?",           opts: ["3.2","4.0","4.8","6.4"] },
    { text: "Which chart best shows the distribution of continuous data?",      opts: ["Pie chart","Bar chart","Histogram","Line graph"] }
  ];
  while (questions.length < TOTAL) {
    questions.push({ text: "Sample question #" + (questions.length + 1) + ". Choose the best answer.", opts: ["Option A","Option B","Option C","Option D"] });
  }

  /* ── Palette ── */
  function buildPalette() {
    var grid = document.getElementById('ignPalette');
    if (!grid) return;
    grid.innerHTML = '';
    for (var i = 0; i < TOTAL; i++) {
      (function (idx) {
        var btn = document.createElement('button');
        btn.className   = 'ign-pal-btn';
        btn.textContent = idx + 1;
        btn.onclick = function () { goTo(idx); };
        grid.appendChild(btn);
      })(i);
    }
  }

  function refreshPalette() {
    var btns = document.querySelectorAll('.ign-pal-btn');
    btns.forEach(function (btn, i) {
      btn.className = 'ign-pal-btn';
      if (i === current)             btn.classList.add('current');
      else if (flagged[i])           btn.classList.add('flagged');
      else if (answers[i] !== null)  btn.classList.add('answered');
    });
    var ans  = answers.filter(function(a){ return a !== null; }).length;
    var flg  = flagged.filter(Boolean).length;
    document.getElementById('ignStatAns').textContent  = ans;
    document.getElementById('ignStatFlag').textContent = flg;
    document.getElementById('ignStatLeft').textContent = TOTAL - ans;
  }

  /* ── Render question ── */
  function render() {
    var q   = questions[current];
    var pct = Math.round(((current + 1) / TOTAL) * 100);
    var pfx = ['A','B','C','D'];

    document.getElementById('ignQNum').textContent   = current + 1;
    document.getElementById('ignBadge').textContent  = 'Q' + (current+1) + ' / ' + TOTAL;
    document.getElementById('ignPct').textContent    = pct + '%';
    document.getElementById('ignFill').style.width   = pct + '%';
    document.getElementById('ignQText').textContent  = q.text;

    var cont = document.getElementById('ignOptions');
    cont.innerHTML = '';
    q.opts.forEach(function (opt, i) {
      var div = document.createElement('div');
      div.className = 'ign-option' + (answers[current] === i ? ' selected' : '');
      div.innerHTML = '<span class="ign-opt-letter">' + pfx[i] + '</span><span class="ign-opt-text">' + opt + '</span>';
      div.onclick   = (function(idx){ return function(){ ignSelect(idx); }; })(i);
      cont.appendChild(div);
    });

    var fb = document.getElementById('ignFlagBtn');
    if (fb) {
      fb.className = 'ign-flag-btn' + (flagged[current] ? ' active' : '');
      fb.innerHTML = flagged[current]
        ? '<i class="fas fa-flag"></i> Flagged'
        : '<i class="far fa-flag"></i> Flag for Review';
    }

    refreshPalette();
  }

  function goTo(idx) { current = Math.max(0, Math.min(TOTAL-1, idx)); render(); }
  window.ignPrev   = function () { goTo(current - 1); };
  window.ignNext   = function () { goTo(current + 1); };
  window.ignSelect = function (idx) { answers[current] = idx; render(); };
  window.ignToggleFlag = function () { flagged[current] = !flagged[current]; render(); };

  window.ignSubmit = function () {
    var ans = answers.filter(function(a){ return a !== null; }).length;
    if (!confirm('You have answered ' + ans + ' of ' + TOTAL + ' questions.\nSubmit the exam now?')) return;
    alert('Exam submitted! Your results will be available shortly.');
  };

  /* ── Timer ── */
  var secs    = 3600;
  var timerEl = document.getElementById('ignTimer');
  var tick    = setInterval(function () {
    secs--;
    if (secs < 0) { clearInterval(tick); if(timerEl) timerEl.textContent = '00:00:00'; return; }
    var h = Math.floor(secs/3600), m = Math.floor((secs%3600)/60), s = secs%60;
    if (timerEl) {
      timerEl.textContent = pad(h)+':'+pad(m)+':'+pad(s);
      timerEl.className   = 'ign-timer' + (secs<300?' danger':secs<600?' warn':'');
    }
  }, 1000);
  function pad(n){ return n<10?'0'+n:n; }

  /* ── Calculator ── */
  var expr = '';
  var disp = document.getElementById('ignCalcDisp');

  window.ignToggleCalc = function () {
    document.getElementById('ignCalcModal').classList.toggle('open');
    document.getElementById('ignCalcOverlay').classList.toggle('open');
  };
  window.ca = function (v) { expr += v; if(disp){ disp.textContent=expr; disp.className='ign-calc-display'; } };
  window.cc = function () { expr=''; if(disp){ disp.textContent='0'; disp.className='ign-calc-display'; } };
  window.cb = function () { expr=expr.slice(0,-1); if(disp) disp.textContent=expr||'0'; };
  window.ce = function () {
    try {
      var result = Function('"use strict";return('+expr+')')();
      expr = String(Math.round(result*1e10)/1e10);
      if(disp){ disp.textContent=expr; disp.className='ign-calc-display'; }
    } catch(e) {
      if(disp){ disp.textContent='Error'; disp.className='ign-calc-display err'; }
      expr='';
    }
  };

  /* ── Init ── */
  buildPalette();
  render();
})();
</script>