    <button class="ign-calc-close" onclick="window.ignToggleCalc()"><i class="fas fa-times"></i></button>
  </div>
  <div class="ign-calc-display" id="ignCalcDisp">0</div>
  <div class="ign-calc-sci">
    <button class="ign-sci-key" onclick="window.ca('Math.sin(')">sin</button>
    <button class="ign-sci-key" onclick="window.ca('Math.cos(')">cos</button>
    <button class="ign-sci-key" onclick="window.ca('Math.tan(')">tan</button>
    <button class="ign-sci-key" onclick="window.ca('Math.asin(')">sin⁻¹</button>
    <button class="ign-sci-key" onclick="window.ca('Math.acos(')">cos⁻¹</button>
    <button class="ign-sci-key" onclick="window.ca('Math.atan(')">tan⁻¹</button>
    <button class="ign-sci-key" onclick="window.ca('Math.log10(')">log</button>
    <button class="ign-sci-key" onclick="window.ca('Math.log(')">ln</button>
    <button class="ign-sci-key" onclick="window.ca('Math.sqrt(')">√</button>
