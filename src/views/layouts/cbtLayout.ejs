  </div>
  <div class="ign-calc-keys">
    <button class="ign-calc-key clr" onclick="window.cc()">C</button>
    <button class="ign-calc-key bk"  onclick="window.cb()">⌫</button>
    <button class="ign-calc-key op"  onclick="window.ca('(')">(</button>
    <button class="ign-calc-key op"  onclick="window.ca(')')">)</button>
    <button class="ign-calc-key"     onclick="window.ca('7')">7</button>
