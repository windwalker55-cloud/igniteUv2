<style>
  /* ===== AI TUTOR — IgniteU Theme ===== */

  .section-nav { display: flex; margin: 0 10px 1.3rem; flex-wrap: wrap; }
  .nav-link {
    padding: 0.45rem 1.1rem; border-radius: 999px;
    font: 600 0.82rem 'Inter', sans-serif; text-decoration: none;
    background: rgba(94,234,212,.06); border: 1px solid var(--line);
    color: var(--muted); transition: background .2s, border-color .2s, color .2s;
  }
  .nav-link:hover  { background: rgba(94,234,212,.1); border-color: var(--line-strong); color: var(--text); }
  .nav-link.active { background: rgba(94,234,212,.15); border-color: var(--mint); color: var(--mint); }

  .page-header { margin: 0 10px 1.1rem; }
  .page-header h2 { font: 700 1.35rem 'Inter', sans-serif; color: var(--text); letter-spacing: -.02em; margin-bottom: .25rem; }
  .page-header p  { font: 400 .8rem 'JetBrains Mono', monospace; color: var(--muted); }

  /* ── Chat wrapper ── */
  .ai-chat-container {
    margin: 0 10px 18px;
    border: 1px solid var(--line);
    border-radius: 16px; overflow: hidden;
    display: flex; flex-direction: column;
    height: 460px;
    background: rgba(10,26,22,.55);
  }

  /* ── Messages area ── */
  .chat-messages {
    flex: 1; overflow-y: auto; padding: 1rem;
    display: flex; flex-direction: column; gap: .7rem;
  }
  .chat-messages::-webkit-scrollbar { width: 3px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--line-strong); border-radius: 10px; }

  /* ── Message rows ── */
  .message { display: flex; gap: .55rem; max-width: 88%; }
  .message.user { margin-left: auto; flex-direction: row-reverse; }

  .message-avatar {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: .8rem;
    background: rgba(94,234,212,.1); border: 1px solid var(--line);
  }
  .message.user .message-avatar { background: rgba(94,234,212,.2); border-color: rgba(94,234,212,.4); }

  /* ── Bubbles ── */
  .message-content {
    background: rgba(94,234,212,.06); border: 1px solid var(--line);
    padding: .6rem .85rem; border-radius: 0 12px 12px 12px; max-width: 100%;
  }
  .message.user .message-content {
    background: rgba(94,234,212,.15); border-color: rgba(94,234,212,.35);
    border-radius: 12px 0 12px 12px;
  }
  .message-text {
    font: 400 .82rem 'Inter', sans-serif;
    color: var(--text); line-height: 1.55; white-space: pre-wrap;
  }
  .message-time {
    font: 400 .6rem 'JetBrains Mono', monospace;
    color: var(--muted-2); margin-top: .25rem;
  }

  /* ── Topic chips ── */
  .topic-chips { display: flex; gap: .4rem; flex-wrap: wrap; margin-top: .6rem; }
  .topic-btn {
    font: 500 .7rem 'Inter', sans-serif; padding: .24rem .75rem;
    border-radius: 999px; cursor: pointer;
    border: 1px solid var(--line); color: var(--mint);
    background: rgba(94,234,212,.08);
    transition: background .2s, border-color .2s;
  }
  .topic-btn:hover { background: rgba(94,234,212,.16); border-color: var(--line-strong); }

  /* ── Typing dots ── */
  .typing-indicator { display: flex; gap: .28rem; padding: .15rem .2rem; align-items: center; }
  .typing-indicator span {
    width: 6px; height: 6px; border-radius: 50%; background: var(--mint);
    animation: ai-bounce 1.4s infinite ease-in-out;
  }
  .typing-indicator span:nth-child(2) { animation-delay: .2s; }
  .typing-indicator span:nth-child(3) { animation-delay: .4s; }
  @keyframes ai-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: .3; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  /* ── Input bar ── */
  .chat-input-area {
    display: flex; gap: .5rem; padding: .7rem;
    border-top: 1px solid var(--line);
    background: rgba(0,0,0,.2);
  }
  .chat-input {
    flex: 1; padding: .55rem 1rem;
    background: rgba(94,234,212,.06); border: 1px solid var(--line);
    border-radius: 999px; color: var(--text);
    font: 400 .83rem 'Inter', sans-serif; outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  .chat-input::placeholder { color: var(--muted-2); }
  .chat-input:focus { border-color: var(--mint); box-shadow: 0 0 0 3px rgba(94,234,212,.12); }

  .chat-send {
    padding: .55rem 1.3rem; border-radius: 999px; border: none; cursor: pointer;
    background: linear-gradient(135deg, var(--mint-deep), var(--mint));
    color: #0d1f1c; font: 600 .8rem 'Inter', sans-serif;
    transition: opacity .2s, transform .15s; white-space: nowrap; flex-shrink: 0;
  }
  .chat-send:hover  { opacity: .85; transform: translateY(-1px); }
  .chat-send:active { opacity: 1; transform: translateY(0); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .section-nav        { justify-content: center; }
    .nav-link           { font-size: 1rem; padding: .5rem 1.3rem; }
    .page-header h2     { font-size: 1.45rem; }
    .page-header p      { font-size: .95rem; }
    .message-text       { font-size: .95rem; }
    .message-time       { font-size: .72rem; }
    .topic-btn          { font-size: .82rem; padding: .3rem .9rem; }
    .chat-input         { font-size: .95rem; padding: .65rem 1.1rem; }
    .chat-send          { font-size: .9rem; padding: .65rem 1.4rem; }
    .chat-input-area    { padding: .85rem; gap: .6rem; }
    .message-avatar     { width: 34px; height: 34px; font-size: .9rem; }
  }

  @media (max-width: 576px) {
    .ai-chat-container  { height: 60vh; min-height: 340px; border-radius: 12px; }
    .nav-link           { font-size: .95rem; padding: .48rem 1.1rem; }
    .page-header h2     { font-size: 1.35rem; }
    .page-header p      { font-size: .9rem; }
    .message-text       { font-size: .9rem; }
    .chat-input         { font-size: .9rem; }
    .chat-send          { font-size: .85rem; }
  }
</style>

<!-- Nav -->
<div class="section-nav">
  <a href="/leaderboard" class="nav-link">🏆 Leaderboard</a>
  <a href="/ai"          class="nav-link active">🤖 AI Tutor</a>
  <a href="/history"     class="nav-link">📜 History</a>
</div>

<!-- Header -->
<div class="page-header">
  <h2>AI Tutor</h2>
  <p>Your personal learning assistant — ask anything about your courses.</p>
</div>

<!-- Chat -->
<div class="ai-chat-container">
  <div class="chat-messages" id="chatMessages">
    <div class="message bot">
      <div class="message-avatar">🤖</div>
      <div class="message-content">
        <div class="message-text">Hello! I'm your AI Tutor. I can help you with exam prep, study strategies, subject tips, and more.</div>
        <div class="topic-chips">
          <button class="topic-btn" onclick="window.aiSend('Exam tips')">📝 Exam tips</button>
          <button class="topic-btn" onclick="window.aiSend('Study methods')">📚 Study methods</button>
          <button class="topic-btn" onclick="window.aiSend('Math help')">🧮 Math help</button>
          <button class="topic-btn" onclick="window.aiSend('Programming tips')">💻 Programming</button>
        </div>
        <div class="message-time">Online</div>
      </div>
    </div>
  </div>
  <div class="chat-input-area">
    <input type="text" class="chat-input" id="chatInput" placeholder="Ask me anything…" autocomplete="off">
    <button class="chat-send" id="sendBtn">Send</button>
  </div>
</div>

<script>
(function () {
  if (window.__aiTutorReady) return;
  window.__aiTutorReady = true;

  var responses = {
    greeting:    ["Hello! How can I help you study today?", "Hi there! Ready to learn something new?", "Hey! What would you like to know?"],
    exam:        "📝 Exam Preparation Tips:\n• Review past questions regularly\n• Practice under timed conditions\n• Focus on weak areas first\n• Take a break every 45 minutes\n• Get enough sleep before exam day",
    study:       "📚 Effective Study Strategies:\n• Pomodoro technique — 25 min study, 5 min break\n• Active recall — test yourself, don't just re-read\n• Spaced repetition for memorisation\n• Teach topics to someone else\n• Write summary notes after each session",
    math:        "🧮 Math Study Tips:\n• Practice daily — consistency beats cramming\n• Understand formulas, don't just memorise them\n• Work step by step and show your working\n• Learn from mistakes — review every error\n• Build confidence by starting with easier problems",
    programming: "💻 Programming Tips:\n• Code every day, even just 30 minutes\n• Break problems into smaller parts\n• Read error messages carefully when debugging\n• Build real projects to apply concepts\n• Use Git from day one",
    science:     "🔬 Science Study Tips:\n• Understand concepts, not just facts\n• Draw diagrams and mind maps\n• Connect topics to real-world examples\n• Review lab procedures regularly\n• Ask 'why' at every step",
    english:     "📖 English / Language Tips:\n• Read widely to build vocabulary\n• Write a little every day\n• Learn grammar rules systematically\n• Speak out loud to improve fluency\n• Use flashcards for new words",
    motivation:  "💪 Stay Motivated:\n• Set small, achievable daily goals\n• Celebrate every win, no matter how small\n• Study with others for accountability\n• Remember why you started\n• Rest is part of the process",
    default:     "Great question! I can help with:\n• Exam preparation\n• Study strategies\n• Subjects — Math, Programming, Science, English\n• Motivation and mindset\n\nJust tell me more about what you need."
  };

  function getResponse(msg) {
    var m = msg.toLowerCase();
    if (m.includes('hello') || m.includes('hi') || m.includes('hey'))
      return responses.greeting[Math.floor(Math.random() * responses.greeting.length)];
    if (m.includes('exam') || m.includes('test') || m.includes('prepare')) return responses.exam;
    if (m.includes('study') || m.includes('learn') || m.includes('revise'))  return responses.study;
    if (m.includes('math') || m.includes('algebra') || m.includes('calculus')) return responses.math;
    if (m.includes('code') || m.includes('program') || m.includes('coding'))  return responses.programming;
    if (m.includes('science') || m.includes('physics') || m.includes('chemistry') || m.includes('biology')) return responses.science;
    if (m.includes('english') || m.includes('language') || m.includes('grammar')) return responses.english;
    if (m.includes('motivat') || m.includes('tired') || m.includes('give up')) return responses.motivation;
    return responses.default;
  }

  function stamp() { return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }); }

  function addMsg(text, isUser) {
    var box = document.getElementById('chatMessages');
    if (!box) return;
    var d = document.createElement('div');
    d.className = 'message ' + (isUser ? 'user' : 'bot');
    d.innerHTML =
      '<div class="message-avatar">' + (isUser ? '👤' : '🤖') + '</div>' +
      '<div class="message-content">' +
        '<div class="message-text">' + text.replace(/\n/g, '<br>') + '</div>' +
        '<div class="message-time">' + stamp() + '</div>' +
      '</div>';
    box.appendChild(d);
    box.scrollTop = box.scrollHeight;
  }

  function showTyping() {
    var box = document.getElementById('chatMessages');
    if (!box) return;
    var d = document.createElement('div');
    d.className = 'message bot'; d.id = 'aiTyping';
    d.innerHTML =
      '<div class="message-avatar">🤖</div>' +
      '<div class="message-content">' +
        '<div class="typing-indicator"><span></span><span></span><span></span></div>' +
      '</div>';
    box.appendChild(d);
    box.scrollTop = box.scrollHeight;
  }

  function hideTyping() { var el = document.getElementById('aiTyping'); if (el) el.remove(); }

  function send() {
    var inp = document.getElementById('chatInput');
    if (!inp) return;
    var msg = inp.value.trim();
    if (!msg) return;
    addMsg(msg, true);
    inp.value = '';
    showTyping();
    setTimeout(function () { hideTyping(); addMsg(getResponse(msg), false); }, 750);
  }

  window.aiSend = function (text) {
    var inp = document.getElementById('chatInput');
    if (inp) inp.value = text;
    send();
  };

  var btn = document.getElementById('sendBtn');
  var inp = document.getElementById('chatInput');
  if (btn) btn.addEventListener('click', send);
  if (inp) inp.addEventListener('keypress', function (e) { if (e.key === 'Enter') send(); });
  if (inp) inp.focus();
})();
</script>