<script>
(function () {
  if (window.__eduReady) return;
  window.__eduReady = true;

  function makeCarousel(opts) {
    var items   = opts.items;
    var INTERVAL = opts.interval || 5000;
    var textEl  = document.getElementById(opts.textId);
    var srcEl   = document.getElementById(opts.sourceId);
    var dotsEl  = document.getElementById(opts.dotsId);
    var fillEl  = document.getElementById(opts.fillId);
    var prevBtn = document.getElementById(opts.prevId);
    var nextBtn = document.getElementById(opts.nextId);

    var today = new Date();
    var idx   = (today.getDate() + today.getMonth() + (opts.offset || 0)) % items.length;
    var timer, progTimer, progStart;

    function buildDots() {
      if (!dotsEl) return;
      dotsEl.innerHTML = items.map(function (_, i) {
        return '<div class="edu-dot' + (i === idx ? ' active' : '') + '" data-i="' + i + '"></div>';
      }).join('');
      dotsEl.querySelectorAll('.edu-dot').forEach(function (dot) {
        dot.addEventListener('click', function () { goTo(parseInt(dot.dataset.i)); });
      });
    }

    function updateDots() {
      if (!dotsEl) return;
      dotsEl.querySelectorAll('.edu-dot').forEach(function (d, i) {
        d.classList.toggle('active', i === idx);
      });
    }

    function startProgress() {
      clearInterval(progTimer);
      if (!fillEl) return;
      fillEl.style.width = '0%';
      progStart = Date.now();
      progTimer = setInterval(function () {
        var pct = Math.min(100, ((Date.now() - progStart) / INTERVAL) * 100);
        fillEl.style.width = pct + '%';
        if (pct >= 100) clearInterval(progTimer);
      }, 50);
    }

    function show(animate) {
      var item = items[idx];
      if (!animate) {
        if (textEl) textEl.textContent = item.text;
        if (srcEl)  srcEl.textContent  = item.source ? '— ' + item.source : '';
        updateDots(); startProgress(); return;
      }
      if (textEl) textEl.classList.add('edu-fading');
      if (srcEl)  srcEl.classList.add('edu-fading');
      setTimeout(function () {
        var it = items[idx];
        if (textEl) { textEl.textContent = it.text; textEl.classList.remove('edu-fading'); }
        if (srcEl)  { srcEl.textContent  = it.source ? '— ' + it.source : ''; srcEl.classList.remove('edu-fading'); }
        updateDots(); startProgress();
      }, 260);
    }

    function goTo(i) {
      idx = (i + items.length) % items.length;
      clearInterval(timer);
      show(true);
      timer = setInterval(function () { idx = (idx + 1) % items.length; show(true); }, INTERVAL);
    }

    buildDots();
    show(false);
    timer = setInterval(function () { idx = (idx + 1) % items.length; show(true); }, INTERVAL);

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(idx - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(idx + 1); });
  }

  /* ── Study Tips ── */
  makeCarousel({
    textId: 'tipText', sourceId: 'tipSource', dotsId: 'tipDots',
    fillId: 'tipFill', prevId: 'tipPrev', nextId: 'tipNext',
    interval: 5000, offset: 0,
    items: [
      { text: "Use the Pomodoro method — study for 25 minutes, then rest for 5. Consistency beats long cramming sessions.", source: "" },
      { text: "Write by hand when memorising key points. Studies show handwriting improves long-term retention.", source: "" },
      { text: "Teach what you just learned to an imaginary student. If you can explain it simply, you truly understand it.", source: "" },
      { text: "Review your notes within 24 hours of a lecture. Forgetting is fastest in the first day — catch it early.", source: "" },
      { text: "Interleave subjects during study sessions instead of blocking one topic all day. It strengthens recall.", source: "" },
      { text: "Sleep is not optional — memory consolidation happens during deep sleep. Aim for 7–9 hours before exams.", source: "" },
      { text: "Use past exam questions as your primary revision tool. Pattern recognition is faster than re-reading notes.", source: "" },
      { text: "Break large topics into small chunks and tackle one chunk per session. Progress feels real and sustainable.", source: "" }
    ]
  });

  /* ── Did You Know ── */
  makeCarousel({
    textId: 'factText', sourceId: 'factSource', dotsId: 'factDots',
    fillId: 'factFill', prevId: 'factPrev', nextId: 'factNext',
    interval: 5000, offset: 3,
    items: [
      { text: "Spaced repetition can improve long-term memory by up to 200% compared to massed practice (cramming).", source: "Cognitive Psychology" },
      { text: "The human brain can store roughly 2.5 petabytes of information — equivalent to 3 million hours of TV.", source: "Neuroscience Research" },
      { text: "Students who take handwritten notes score higher on conceptual questions than those who type their notes.", source: "Mueller & Oppenheimer, 2014" },
      { text: "Exercise before studying increases BDNF — a protein that strengthens neural connections and aids learning.", source: "Harvard Medical School" },
      { text: "Reading aloud improves memory recall significantly — a phenomenon called the 'production effect'.", source: "University of Waterloo, 2017" },
      { text: "The Feynman Technique (explain simply → find gaps → revise) is one of the most effective learning strategies known.", source: "Richard Feynman, Nobel Laureate" },
      { text: "Albert Einstein did not speak fluently until age 9. Late development does not determine future capability.", source: "Historical Record" },
      { text: "Mathematics is the only language shared by all human cultures and is considered a universal language.", source: "Philosophy of Science" }
    ]
  });
})();
</script>