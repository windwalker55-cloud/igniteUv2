<style>
  /* ===== QUICK ACCESS — IgniteU Theme ===== */
  .quick-access {
    position: relative;
    background: linear-gradient(160deg, rgba(94,234,212,.06), rgba(2,16,30,.6));
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 1.3rem 1.3rem;
    margin: 0 10px 18px 10px;
    overflow: hidden;
  }

  /* top shimmer line */
  .quick-access::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--mint), transparent);
    opacity: .4;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.1rem;
    flex-wrap: wrap;
    gap: .5rem;
  }

  .section-header h2 {
    font: 700 1rem 'Inter', sans-serif;
    color: var(--text);
    letter-spacing: -.01em;
  }

  /* 2-col grid, collapses to 1 on small screens */
  .quick-access-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
  }

  /* card */
  .access-card {
    position: relative;
    background: rgba(94,234,212,.04);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1rem;
    cursor: pointer;
    transition: background .25s, border-color .25s, transform .25s, box-shadow .25s;
    display: flex;
    flex-direction: column;
    gap: .1rem;
    overflow: hidden;
  }

  .access-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at top left, rgba(94,234,212,.06), transparent 70%);
    opacity: 0;
    transition: opacity .3s;
    pointer-events: none;
  }

  .access-card:hover {
    background: rgba(94,234,212,.09);
    border-color: var(--line-strong);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(94,234,212,.12);
  }
  .access-card:hover::after { opacity: 1; }

  /* icon */
  .access-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
    margin-bottom: 0.7rem;
    flex-shrink: 0;
  }

  /* text */
  .access-content h3 {
    font: 600 0.9rem 'Inter', sans-serif;
    color: var(--text);
    margin-bottom: 0.25rem;
    letter-spacing: -.01em;
  }

  .access-content p {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 0.6rem;
  }

  /* button */
  .access-action { margin-top: auto; }

  .access-btn {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    background: linear-gradient(135deg, var(--mint-bright), var(--mint-deep));
    color: #022;
    font: 600 0.78rem 'Inter', sans-serif;
    letter-spacing: -.01em;
    box-shadow: 0 4px 16px rgba(94,234,212,.3);
    transition: transform .2s, box-shadow .2s;
  }

  .access-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 22px rgba(94,234,212,.45);
  }

  .access-btn:active { transform: translateY(0); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .quick-access { margin: 0 6px 14px 6px; padding: 1.1rem; }
    .section-header h2 { font-size: 1.05rem; }
    .access-icon { width: 46px; height: 46px; font-size: 1.4rem; }
    .access-content h3 { font-size: 0.95rem; }
    .access-content p  { font-size: 0.78rem; }
    .access-btn { font-size: 0.82rem; padding: 0.55rem; }
  }

  @media (max-width: 576px) {
    .quick-access-grid { grid-template-columns: 1fr; }
    .access-card { flex-direction: row; align-items: center; gap: 0.9rem; padding: 0.85rem 1rem; }
    .access-icon { margin-bottom: 0; flex-shrink: 0; }
    .access-content { flex: 1; }
    .access-content p { margin-bottom: 0; }
    .access-action { flex-shrink: 0; }
    .access-btn { width: auto; padding: 0.5rem 1.1rem; white-space: nowrap; }
  }

  @media (max-width: 380px) {
    .quick-access { padding: 0.9rem; }
    .access-icon { width: 38px; height: 38px; font-size: 1.1rem; }
    .access-content h3 { font-size: 0.88rem; }
    .access-content p  { font-size: 0.72rem; }
  }
</style>

<div class="quick-access">
  <div class="section-header">
