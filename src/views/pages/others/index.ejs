<style>
  /* ===== QUICK ACCESS — IgniteU Theme ===== */
  .quick-access {
    position: relative;
    background: linear-gradient(160deg, rgba(94,234,212,.06), rgba(2,16,30,.6));
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 1.3rem 1.3rem;
    margin: 0 10px 18px 10px;
    overflow: hidden;
  }
  .quick-access::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--mint), transparent);
    opacity: .4;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.1rem;
    flex-wrap: wrap;
    gap: .5rem;
  }
  .section-header h2 {
    font: 700 1rem 'Inter', sans-serif;
    color: var(--text);
    letter-spacing: -.01em;
  }
  .quick-access-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
  }
  .access-card {
    position: relative;
    background: rgba(94,234,212,.04);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1rem;
    cursor: pointer;
    transition: background .25s, border-color .25s, transform .25s, box-shadow .25s;
    display: flex;
    flex-direction: column;
    gap: .1rem;
    overflow: hidden;
  }
  .access-card::after {
    content: "";
    position: absolute; inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at top left, rgba(94,234,212,.06), transparent 70%);
    opacity: 0; transition: opacity .3s; pointer-events: none;
  }
  .access-card:hover { background: rgba(94,234,212,.09); border-color: var(--line-strong); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(94,234,212,.12); }
  .access-card:hover::after { opacity: 1; }
  .access-icon {
    width: 42px; height: 42px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; margin-bottom: 0.7rem; flex-shrink: 0;
  }
  .access-content h3 { font: 600 0.9rem 'Inter', sans-serif; color: var(--text); margin-bottom: 0.25rem; letter-spacing: -.01em; }
  .access-content p  { font-size: 0.75rem; color: var(--muted); line-height: 1.5; margin-bottom: 0.6rem; }
  .access-action { margin-top: auto; }
  .access-btn {
    width: 100%; padding: 0.5rem 0.75rem; border-radius: 999px; border: none; cursor: pointer;
    background: linear-gradient(135deg, var(--mint-bright), var(--mint-deep));
    color: #022; font: 600 0.78rem 'Inter', sans-serif; letter-spacing: -.01em;
    box-shadow: 0 4px 16px rgba(94,234,212,.3); transition: transform .2s, box-shadow .2s;
  }
  .access-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 22px rgba(94,234,212,.45); }
  .access-btn:active { transform: translateY(0); }

  /* ===== EDU STRIP ===== */
  .edu-strip {
    margin: 0 10px 18px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .7rem;
  }
  .edu-card {
    position: relative;
    background: rgba(94,234,212,.04);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: .85rem 1rem .8rem;
    overflow: hidden;
    transition: background .2s, border-color .2s;
    display: flex; flex-direction: column;
  }
  .edu-card:hover { background: rgba(94,234,212,.07); border-color: var(--line-strong); }
  .edu-card::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--mint), transparent); opacity: .3;
  }
  .edu-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: .45rem; }
  .edu-card-label {
    font: 600 .62rem 'JetBrains Mono', monospace;
    color: var(--mint); letter-spacing: 1.5px; text-transform: uppercase;
    display: flex; align-items: center; gap: .35rem;
  }
  .edu-arrows { display: flex; gap: .3rem; }
  .edu-arrow {
    width: 24px; height: 24px; border-radius: 50%;
    border: 1px solid var(--line); background: rgba(94,234,212,.07);
    color: var(--mint); display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: .6rem;
    transition: background .2s, border-color .2s, transform .15s;
  }
  .edu-arrow:hover { background: rgba(94,234,212,.16); border-color: var(--line-strong); transform: scale(1.1); }
  .edu-arrow:active { transform: scale(.92); }
  .edu-card-text   { font: 400 .8rem 'Inter', sans-serif; color: var(--text); line-height: 1.55; flex: 1; transition: opacity .25s, transform .25s; }
  .edu-card-source { font: 400 .63rem 'JetBrains Mono', monospace; color: var(--muted-2); margin-top: .25rem; min-height: .85rem; transition: opacity .25s; }
  .edu-fading { opacity: 0; transform: translateY(4px); }
  .edu-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: .55rem; }
  .edu-dots { display: flex; gap: .32rem; flex-wrap: wrap; }
  .edu-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--line-strong); cursor: pointer; transition: background .2s, transform .15s; }
  .edu-dot.active { background: var(--mint); transform: scale(1.3); }
  .edu-progress { height: 2px; width: 60px; border-radius: 999px; background: var(--line); overflow: hidden; display: none; }
  .edu-progress-fill { height: 100%; width: 0%; background: var(--mint); border-radius: 999px; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    /* quick access */
    .quick-access       { margin: 0 8px 16px 8px; padding: 1.4rem 1.3rem; }
    .section-header h2  { font-size: 1.2rem; }
    .access-icon        { width: 50px; height: 50px; font-size: 1.5rem; }
    .access-content h3  { font-size: 1.05rem; }
    .access-content p   { font-size: .88rem; }
    .access-btn         { font-size: .9rem; padding: 0.6rem; }
    /* edu strip */
    .edu-strip          { margin: 0 8px 16px; }
    .edu-card-label     { font-size: .7rem; }
    .edu-card-text      { font-size: .88rem; }
  }

  @media (max-width: 576px) {
    /* quick access — row layout */
    .quick-access-grid  { grid-template-columns: 1fr; }
    .access-card        { flex-direction: row; align-items: center; gap: 0.9rem; padding: 0.95rem 1rem; }
    .access-icon        { margin-bottom: 0; width: 48px; height: 48px; font-size: 1.4rem; }
    .access-content     { flex: 1; }
    .access-content p   { margin-bottom: 0; font-size: .85rem; }
    .access-content h3  { font-size: 1rem; }
    .access-action      { flex-shrink: 0; }
    .access-btn         { width: auto; padding: 0.55rem 1.2rem; white-space: nowrap; font-size: .88rem; }
    /* edu strip — stack */
    .edu-strip          { grid-template-columns: 1fr; }
    .edu-card-text      { font-size: .85rem; }
  }

  @media (max-width: 380px) {
    .quick-access       { padding: 1rem; }
    .access-icon        { width: 44px; height: 44px; font-size: 1.25rem; }
    .access-content h3  { font-size: .95rem; }
    .access-content p   { font-size: .82rem; }
    .access-btn         { font-size: .84rem; padding: 0.5rem 1rem; }
  }
</style>


