<style>
  /* ===== STUDY MATERIALS — IgniteU Theme ===== */

  /* Stats bar */
  .mat-stats-bar { display: flex; gap: .6rem; flex-wrap: wrap; margin: 0 10px 1.1rem; }
  .mat-stat {
    display: flex; align-items: center; gap: .45rem;
    background: rgba(94,234,212,.05); border: 1px solid var(--line);
    border-radius: 999px; padding: .28rem .85rem;
    font: 500 .7rem 'JetBrains Mono', monospace; color: var(--muted);
  }
  .mat-stat i { color: var(--mint); font-size: .72rem; }

  /* Search */
  .search-container { margin: 0 10px 1rem; }
  .search-wrapper { position: relative; display: flex; align-items: center; }
  .search-icon {
    position: absolute; left: .9rem; top: 50%; transform: translateY(-50%);
    color: var(--muted); pointer-events: none;
  }
  .search-bar {
    width: 100%; padding: .6rem 1rem .6rem 2.6rem;
    background: rgba(94,234,212,.05); border: 1px solid var(--line);
    border-radius: 999px; color: var(--text);
    font: 400 .82rem 'Inter', sans-serif; outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  .search-bar::placeholder { color: var(--muted-2); }
  .search-bar:focus { border-color: var(--mint); box-shadow: 0 0 0 3px rgba(94,234,212,.12); }
  .search-hint { font: 400 .68rem 'JetBrains Mono', monospace; color: var(--muted-2); margin-top: .4rem; padding-left: .2rem; }

  /* Page header */
  .page-header { margin: 0 10px 1rem; }
  .page-header h1 { font: 700 1.35rem 'Inter', sans-serif; color: var(--text); letter-spacing: -.02em; margin-bottom: .2rem; }
  .page-header p  { font: 400 .8rem 'JetBrains Mono', monospace; color: var(--muted); }

  /* Filters */
  .category-filters { display: flex; gap: .45rem; flex-wrap: wrap; margin: 0 10px 1.1rem; }
  .filter-btn {
    padding: .3rem 1rem; border-radius: 999px;
    font: 600 .72rem 'Inter', sans-serif; cursor: pointer;
    background: rgba(94,234,212,.05); border: 1px solid var(--line);
    color: var(--muted); transition: background .2s, border-color .2s, color .2s;
  }
  .filter-btn:hover  { background: rgba(94,234,212,.1);  border-color: var(--line-strong); color: var(--text); }
  .filter-btn.active { background: rgba(94,234,212,.15); border-color: var(--mint);        color: var(--mint); }

  /* Grid */
  .materials-grid {
    list-style: none; padding: 0; margin: 0 10px 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: .75rem;
  }

  /* Card */
  .material-card {
    background: rgba(94,234,212,.04); border: 1px solid var(--line);
    border-radius: 14px; padding: 1rem 1.1rem;
    display: flex; gap: .85rem; position: relative; overflow: hidden;
    transition: background .15s, border-color .15s, transform .15s;
  }
  .material-card::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--mint), transparent);
    opacity: 0; transition: opacity .2s;
  }
  .material-card:hover { background: rgba(94,234,212,.08); border-color: var(--line-strong); transform: translateY(-2px); }
  .material-card:hover::before { opacity: .3; }

  .material-icon    { font-size: 1.9rem; flex-shrink: 0; line-height: 1; padding-top: .1rem; }
  .material-content { flex: 1; min-width: 0; }
  .material-title   { font: 600 .88rem 'Inter', sans-serif; color: var(--text); margin-bottom: .35rem; line-height: 1.35; }

  .material-meta { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: .4rem; }
  .material-course {
    background: rgba(94,234,212,.12); color: var(--mint);
    border: 1px solid rgba(94,234,212,.25);
    padding: .15rem .5rem; border-radius: 4px;
    font: 600 .6rem 'JetBrains Mono', monospace; letter-spacing: .5px;
  }
  .material-type {
    background: rgba(94,234,212,.05); color: var(--muted);
    border: 1px solid var(--line);
    padding: .15rem .5rem; border-radius: 4px;
    font: 400 .6rem 'JetBrains Mono', monospace;
  }

  .material-description { font: 400 .77rem 'Inter', sans-serif; color: var(--muted); line-height: 1.5; margin-bottom: .7rem; }

  .material-footer { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .5rem; }
  .material-stats  { display: flex; gap: .55rem; font: 400 .62rem 'JetBrains Mono', monospace; color: var(--muted-2); flex-wrap: wrap; }

  .download-btn {
    display: inline-flex; align-items: center; gap: .35rem;
    padding: .38rem 1rem; border-radius: 999px; border: none; cursor: pointer;
    background: linear-gradient(135deg, var(--mint-deep), var(--mint));
    color: #0d1f1c; font: 600 .72rem 'Inter', sans-serif;
    transition: opacity .2s, transform .15s; white-space: nowrap; flex-shrink: 0;
  }
  .download-btn:hover    { opacity: .85; transform: translateY(-1px); }
  .download-btn:active   { opacity: 1;   transform: translateY(0);    }
  .download-btn:disabled { opacity: .7;  cursor: not-allowed; transform: none; }

  /* No results */
  .no-results {
    display: none; text-align: center; padding: 3rem 1rem; margin: 0 10px;
    color: var(--muted); font: 400 .85rem 'JetBrains Mono', monospace;
  }

  /* Load More */
  .mat-load-wrap { text-align: center; margin: .5rem 10px 18px; }
  .mat-load-wrap.hidden { display: none; }
  .mat-load-btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .6rem 1.8rem; border-radius: 999px;
    border: 1px solid var(--line-strong); background: rgba(94,234,212,.07);
    color: var(--mint); font: 600 .82rem 'Inter', sans-serif; cursor: pointer;
    transition: background .2s, box-shadow .2s, transform .15s;
  }
  .mat-load-btn:hover  { background: rgba(94,234,212,.14); box-shadow: 0 4px 18px rgba(94,234,212,.2); transform: translateY(-1px); }
  .mat-load-btn:active { transform: translateY(0); }

  /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
    .materials-grid     { grid-template-columns: 1fr; }
