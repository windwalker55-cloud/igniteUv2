  var searchQuery    = '';
  var shown          = STEP;

  window.dlMat = function (btn, filename) {
    var orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Downloading…';
    btn.disabled = true;
    setTimeout(function () {
      btn.innerHTML = '<i class="fa-solid fa-check"></i> Done!';
      setTimeout(function () { btn.innerHTML = orig; btn.disabled = false; }, 1500);
    }, 1200);
  };

  function applyFilters() {
    var allCards = Array.from(document.querySelectorAll('#materialsGrid .material-card'));
    var q = searchQuery.toLowerCase().trim();

    var matched = allCards.filter(function (card) {
      var catOk = activeCategory === 'all' || card.dataset.category === activeCategory;
      var text  = (card.dataset.search || '') + ' ' + card.textContent.toLowerCase();
      var qOk   = !q || text.includes(q);
      return catOk && qOk;
    });

    allCards.forEach(function (c) { c.style.display = 'none'; });
    matched.slice(0, shown).forEach(function (c) { c.style.display = ''; });

    var noRes = document.getElementById('matNoResults');
    if (noRes) noRes.style.display = matched.length === 0 ? 'block' : 'none';

    var wrap = document.getElementById('matLoadWrap');
    var btn  = document.getElementById('matLoadBtn');
    if (wrap && btn) {
      if (matched.length > shown) {
        var remaining = Math.min(matched.length - shown, STEP);
        btn.innerHTML = '<i class="fa-solid fa-chevron-down"></i> Load ' + remaining + ' More';
        wrap.classList.remove('hidden');
      } else {
        wrap.classList.add('hidden');
      }
    }
  }

  document.querySelectorAll('.filter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      activeCategory = btn.dataset.category;
      shown = STEP;
      document.querySelectorAll('.filter-btn').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      applyFilters();
    });
  });

  var searchEl = document.getElementById('matSearch');
  if (searchEl) searchEl.addEventListener('input', function () {
    searchQuery = this.value;
    shown = STEP;
    applyFilters();
  });

  var loadBtn = document.getElementById('matLoadBtn');
  if (loadBtn) loadBtn.addEventListener('click', function () {
    shown += STEP;
    applyFilters();
  });

  applyFilters();
})();
</script>