<!-- Load More -->
<div class="load-more-container" id="loadMoreContainer">
  <button class="load-more-btn" id="loadMoreBtn">
    <i class="fa-solid fa-chevron-down"></i> Load More Courses
  </button>
</div>

<script>
(function () {
  var SHOW_INIT = 6, SHOW_STEP = 6;
  var allItems    = Array.from(document.querySelectorAll('.course-item:not(.no-results)'));
  var noResults   = document.getElementById('noResults');
  var countEl     = document.getElementById('courseCount');
  var loadBtn     = document.getElementById('loadMoreBtn');
  var loadWrap    = document.getElementById('loadMoreContainer');
  var searchInput = document.getElementById('courseSearch');
  var totalVisible = SHOW_INIT, query = '';

  searchInput.addEventListener('input', function () {
    query = this.value.trim().toLowerCase();
    totalVisible = SHOW_INIT;
    render();
  });

  loadBtn.addEventListener('click', function () {
    totalVisible += SHOW_STEP;
    render();
  });

  function render() {
    var matched = allItems.filter(function (li) {
      if (!query) return true;
      var haystack = [
        li.dataset.search || '',
        (li.querySelector('.course-title')       || {}).textContent || '',
        (li.querySelector('.course-code')        || {}).textContent || '',
        (li.querySelector('.course-description') || {}).textContent || ''
      ].join(' ').toLowerCase();
      return haystack.includes(query);
    });

    allItems.forEach(function (li) { li.style.display = 'none'; });

    matched.forEach(function (li, i) {
      if (i < totalVisible) li.style.display = 'list-item';
    });

    noResults.style.display = (matched.length === 0 && query) ? 'block' : 'none';
    if (matched.length === 0 && query) document.getElementById('noResultsTerm').textContent = query;

    var showing = Math.min(matched.length, totalVisible);
    countEl.textContent = query
      ? showing + ' of ' + matched.length + ' courses match "' + query + '"'
      : allItems.length + ' Courses Available';

    if (matched.length > totalVisible) {
      loadWrap.classList.remove('hidden');
      var left = matched.length - totalVisible;
      loadBtn.innerHTML = '<i class="fa-solid fa-chevron-down"></i> Load ' + Math.min(left, SHOW_STEP) + ' More Courses';
    } else {
      loadWrap.classList.add('hidden');
    }
  }

  render();
})();
</script>