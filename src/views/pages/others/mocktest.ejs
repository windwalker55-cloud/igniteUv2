<style>
  /* ===== MOCK TEST COURSE SELECTION — IgniteU Theme ===== */
  .search-container { margin: 0 10px 1.4rem; max-width: 560px; }
  .search-wrapper   { position: relative; display: flex; align-items: center; }
  .search-icon {
    position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
    color: var(--muted-2); pointer-events: none; width: 16px; height: 16px;
  }
  .search-bar {
    width: 100%; padding: .82rem 1rem .82rem 2.8rem;
    background: rgba(94,234,212,.04); border: 1px solid var(--line);
    border-radius: 12px; color: var(--text);
    font: 400 .92rem 'Inter', sans-serif; outline: none;
    transition: border-color .25s, box-shadow .25s, background .25s;
  }
  .search-bar::placeholder { color: var(--muted-2); }
  .search-bar:focus {
    border-color: var(--mint); background: rgba(94,234,212,.07);
    box-shadow: 0 0 0 3px rgba(94,234,212,.12);
  }
  .search-hint {
    font: 400 .72rem 'JetBrains Mono', monospace;
    color: var(--muted-2); margin-top: .45rem; margin-left: .25rem; letter-spacing: .3px;
  }
  .page-header { margin: 0 10px 1.2rem; }
  .page-header h1 {
    font: 700 1.2rem 'Inter', sans-serif;
    color: var(--text); letter-spacing: -.02em; margin-bottom: .2rem;
  }
  .page-header p { font: 400 .78rem 'JetBrains Mono', monospace; color: var(--muted); letter-spacing: .3px; }
  .no-results {
    display: none; padding: 2.5rem 1rem; text-align: center;
    color: var(--muted); font: 400 .88rem 'JetBrains Mono', monospace; grid-column: 1 / -1;
  }
  .no-results i { display: block; font-size: 2rem; margin-bottom: .75rem; color: var(--muted-2); }
  .course-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem; padding: 0; list-style: none; margin: 0 10px;
  }
  .course-item.hidden-card { display: none; }
  .course-item.hidden-card.shown { display: list-item; }
  .course-card {
    position: relative; background: rgba(94,234,212,.04); border: 1px solid var(--line);
    border-radius: 14px; padding: 1rem 1rem .9rem; display: block;
    text-decoration: none; transition: background .2s, border-color .2s, transform .2s, box-shadow .2s; height: 100%;
  }
  .course-card:hover {
    background: rgba(94,234,212,.08); border-color: var(--line-strong);
    transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.25);
  }
  .course-badge {
    position: absolute; top: .9rem; right: .9rem;
    background: rgba(94,234,212,.12); border: 1px solid rgba(94,234,212,.25);
    color: var(--mint); padding: .18rem .6rem; border-radius: 999px;
    font: 600 .68rem 'JetBrains Mono', monospace; letter-spacing: .5px; white-space: nowrap;
  }
  .course-title {
    font: 700 .95rem 'Inter', sans-serif; color: var(--text);
    margin-bottom: .25rem; padding-right: 56px; letter-spacing: -.01em; line-height: 1.3;
  }
  .course-code {
    font: 600 .72rem 'JetBrains Mono', monospace;
    color: var(--mint); letter-spacing: 1px; margin-bottom: .5rem;
  }
  .course-description {
    font: 400 .78rem 'Inter', sans-serif; color: var(--muted); line-height: 1.5; margin-bottom: .6rem;
  }
  .course-divider { height: 1px; background: var(--line); margin: .7rem 0 .55rem; }
  .course-meta {
    display: flex; justify-content: space-between; align-items: center;
    font: 400 .7rem 'JetBrains Mono', monospace; color: var(--muted-2);
  }
  .course-level, .course-semester { display: flex; align-items: center; gap: .3rem; }
  .load-more-container { text-align: center; margin: 1.2rem 10px 18px; }
  .load-more-container.hidden { display: none; }
  .load-more-btn {
    display: inline-flex; align-items: center; gap: .55rem;
    padding: .65rem 1.8rem; border-radius: 999px; border: 1px solid var(--line-strong);
    background: rgba(94,234,212,.07); color: var(--mint);
    font: 600 .85rem 'Inter', sans-serif; cursor: pointer; letter-spacing: -.01em;
    transition: background .2s, box-shadow .2s, transform .2s;
  }
  .load-more-btn:hover {
    background: rgba(94,234,212,.14); box-shadow: 0 4px 18px rgba(94,234,212,.2); transform: translateY(-1px);
  }
  .load-more-btn:active { transform: translateY(0); }
  .load-more-btn i { font-size: .8rem; transition: transform .3s; }
  .load-more-btn:hover i { transform: translateY(2px); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .course-grid        { grid-template-columns: 1fr; gap: .8rem; }
    .search-bar         { font-size: .88rem; padding: .82rem 1rem .82rem 2.8rem; }
    .search-hint        { font-size: .72rem; }
    .page-header h1     { font-size: 1.15rem; }
    .page-header p      { font-size: .8rem; }
    .course-title       { font-size: .92rem; }
    .course-code        { font-size: .72rem; }
    .course-description { font-size: .78rem; }
    .course-meta        { font-size: .68rem; }
    .course-badge       { font-size: .65rem; padding: .18rem .6rem; }
    .load-more-btn      { font-size: .85rem; padding: .65rem 1.8rem; }
    .no-results         { font-size: .85rem; }
  }
  @media (max-width: 480px) {
    .course-badge       { font-size: .62rem; }
    .course-title       { font-size: .88rem; padding-right: 50px; }
    .course-meta        { font-size: .65rem; }
    .page-header h1     { font-size: 1.05rem; }
  }
</style>

<!-- Search -->
